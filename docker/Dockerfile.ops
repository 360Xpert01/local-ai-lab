FROM golang:1.21-alpine as builder

WORKDIR /app

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source
COPY . .

# Build
RUN CGO_ENABLED=0 GOOS=linux go build -o ops-agent ./cmd/server

# Runtime image
FROM alpine:latest

WORKDIR /app

# Install docker-cli for docker operations
RUN apk add --no-cache docker-cli

COPY --from=builder /app/ops-agent /app/ops-agent

EXPOSE 8082

CMD ["./ops-agent"]
